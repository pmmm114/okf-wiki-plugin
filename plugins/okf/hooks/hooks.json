{
  "description": "OKF bundle context injection",
  "hooks": {
    "SessionStart": [
      { "hooks": [ { "type": "command",
          "command": "${CLAUDE_PLUGIN_ROOT}/bin/okf-py",
          "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/core/okf_hooks.py", "session-start"] } ] },
      { "hooks": [ { "type": "command",
          "command": "${CLAUDE_PLUGIN_ROOT}/bin/okf-py",
          "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/study/study_session.py"] } ] } ],
    "PostToolUse": [
      { "matcher": "Write|Edit",
        "hooks": [ { "type": "command",
          "command": "${CLAUDE_PLUGIN_ROOT}/scripts/post_tool_use.sh", "args": [] } ] },
      { "matcher": "Write",
        "hooks": [ { "type": "command",
          "command": "${CLAUDE_PLUGIN_ROOT}/bin/okf-py",
          "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/study/study_hook.py"] } ] } ],
    "FileChanged": [
      { "hooks": [ { "type": "command",
          "command": "${CLAUDE_PLUGIN_ROOT}/scripts/file_changed.sh", "args": [] } ] } ]
  }
}
